# === Core ===
SECRET_KEY=change-me-to-random-string
DB_ENCRYPTION_KEY=change-me-to-random-string
DEBUG=false

# === Environment ===
ENVIRONMENT=development  # development | staging | production

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional frontend-style aliases accepted by backend as fallback:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# === Google OAuth ===
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# === Stripe Billing ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_FAMILY_PLUS_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_FAMILY_PLUS_ANNUAL_PRICE_ID=price_...
STRIPE_SELF_HOSTED_PRICE_ID=price_...

# === Email (SMTP) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=true

# === Self-Hosted License ===
SYNCO_LICENSE_KEY=           # License key from purchase (self-hosted only)
# SYNCO_LICENSE_SECRET=      # Admin-only: secret for generating keys

# === Production ===
ALLOWED_ORIGINS=https://synco.app,https://www.synco.app
LOG_LEVEL=INFO
LOG_FORMAT=json  # text | json
WEB_CONCURRENCY=3
SENTRY_DSN=
