# ==============================
# Synco Self-Hosted Configuration
# ==============================
# Copy this file to .env and fill in the values.
# Required fields are marked with (REQUIRED).

# === Core (REQUIRED) ===
SECRET_KEY=change-me-to-a-random-64-char-string
DB_ENCRYPTION_KEY=change-me-to-a-random-64-char-string

# === License (REQUIRED) ===
# Your license key from https://synco.app/pricing
SYNCO_LICENSE_KEY=SYNCO-xxxxxxxx-xxxxxxxx-xxxxxxxx-xxxxxxxx-xxxxxxxx

# === Database (REQUIRED) ===
POSTGRES_PASSWORD=change-me-to-a-strong-password

# === PostgREST JWT ===
# Generate with: openssl rand -base64 32
PGRST_JWT_SECRET=change-me-to-a-random-base64-secret

# === Supabase Keys ===
# Auto-configured for local PostgREST; override only if using external Supabase
SUPABASE_URL=http://rest:3000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Domain & HTTPS (REQUIRED for production) ===
# Your domain name pointed at this server (Caddy handles HTTPS automatically)
SITE_DOMAIN=localhost

# === Google Calendar Integration (optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback

# === Stripe Billing (optional for self-hosted) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_FAMILY_PLUS_PRICE_ID=

# === Email / SMTP (optional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=true

# === Monitoring (optional) ===
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json
WEB_CONCURRENCY=3
